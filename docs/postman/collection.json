{
  "info": {
    "name": "Cashflow API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Transaction",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Tenant-Id",
            "value": "{{tenantId}}",
            "type": "text"
          },
          {
            "key": "X-Idempotence-Key",
            "value": "{{idempotenceKey}}",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer token",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/transactions",
          "host": ["{{baseUrl}}"],
          "path": ["transactions"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 100.0,\n  \"type\": \"Credit\"\n}"
        }
      }
    },
    {
      "name": "Get Transactions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Tenant-Id",
            "value": "{{tenantId}}",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer token",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/transactions?accountId={{accountId}}&startDate={{startDate}}&endDate={{endDate}}",
          "host": ["{{baseUrl}}"],
          "path": ["transactions"],
          "query": [
            { "key": "accountId", "value": "{{accountId}}" },
            { "key": "startDate", "value": "{{startDate}}" },
            { "key": "endDate", "value": "{{endDate}}" }
          ]
        }
      }
    },
    {
      "name": "Get Daily Balance",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Tenant-Id",
            "value": "{{tenantId}}",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer token",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/balances/daily?startDate={{startDate}}",
          "host": ["{{baseUrl}}"],
          "path": ["balances", "daily"],
          "query": [
            { "key": "startDate", "value": "{{startDate}}" }
          ]
        }
      }
    },
    {
      "name": "Rebuild Balances",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Tenant-Id",
            "value": "{{tenantId}}",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer token",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/balances/rebuild",
          "host": ["{{baseUrl}}"],
          "path": ["balances", "rebuild"]
        }
      }
    },
    {
      "name": "Rate Limit - POST /transactions",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Deve retornar 429 apos exceder limite de POST /transactions', function () {",
              "    var status = pm.response.code;",
              "    if (pm.iteration === 50) {",
              "        pm.expect(status).to.be.oneOf([200,201,400,401]);",
              "    }",
              "    if (pm.iteration > 50) {",
              "        pm.expect(status).to.eql(429);",
              "        var body = pm.response.json();",
              "        pm.expect(body).to.have.property('error');",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-Tenant-Id", "value": "{{tenantId}}", "type": "text" },
          { "key": "X-Idempotence-Key", "value": "{{idempotenceKey}}", "type": "text" },
          { "key": "Authorization", "value": "Bearer token", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/transactions",
          "host": ["{{baseUrl}}"],
          "path": ["transactions"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 100.0,\n  \"type\": \"Credit\"\n}"
        }
      }
    },
