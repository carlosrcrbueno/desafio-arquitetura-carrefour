<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Clear any user/machine-level sources (including the broken GitLab feed) -->
    <clear />
    <!-- Standard public NuGet feed -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
